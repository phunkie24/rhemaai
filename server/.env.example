# =====================================================
# RhemaAI Technologies — Server Environment Variables
# Copy this to .env and fill in your values
# =====================================================

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rhemaai?retryWrites=true&w=majority

# Email (use a Gmail App Password — not your main password)
# Go to: Google Account > Security > App passwords
EMAIL_USER=hello@rhemaai.tech
EMAIL_PASS=your_gmail_app_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Production values
# FRONTEND_URL=https://rhemaai.tech
# NODE_ENV=production
