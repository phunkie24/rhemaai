# =====================================================
# RhemaAI Solutions Ltd - Server environment variables
# Copy this to .env and fill in your values.
# =====================================================

NODE_ENV=development
PORT=5000

# Local Docker MongoDB:
# MONGODB_URI=mongodb://localhost:27017/rhemaai

# MongoDB Atlas:
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rhemaai?retryWrites=true&w=majority

# Frontend URL for CORS. Use comma-separated values if needed.
FRONTEND_URL=http://localhost:5173

# Required for protected admin access in production.
CONTACT_ADMIN_KEY=replace_with_a_long_random_secret

# Email delivery. Use a Gmail App Password, not your main password.
EMAIL_USER=hello@rhemaai.tech
EMAIL_PASS=your_gmail_app_password

# Production example:
# NODE_ENV=production
# FRONTEND_URL=https://rhemaai.tech,https://www.rhemaai.tech
