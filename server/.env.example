# =====================================================
# RhemaAI Technologies — Server environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# =====================================================

NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────
# Local (dev / VPS direct install):
MONGODB_URI=mongodb://127.0.0.1:27017/rhemaai

# MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rhemaai?retryWrites=true&w=majority

# ── CORS ──────────────────────────────────────────────
# Dev:
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://rhemaai.tech

# ── Email (Gmail App Password) ────────────────────────
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=info@rhemaai.tech
EMAIL_PASS=your_16_char_app_password
