# =====================================================
# RhemaAI Solutions Ltd - Docker Compose environment
# Copy to .env and fill in production values:
#   cp .env.example .env
# =====================================================

# Required in production. Use your live domain after DNS is pointed at the VPS.
FRONTEND_URL=https://rhemaai.tech

# Required in production for protected admin access to GET /api/contact.
# Generate a long random value and keep it private.
CONTACT_ADMIN_KEY=replace_with_a_long_random_secret

# Gmail credentials for contact form emails.
# Use a Gmail App Password, not your main Google password.
EMAIL_USER=hello@rhemaai.tech
EMAIL_PASS=your_gmail_app_password
